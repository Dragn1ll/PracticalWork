{
  "App": {
    "DbConnectionString": "User ID=postgres;Password=postgres;Host=localhost;Port=5433;Database=library;Pooling=true;",
    "Redis": {
      "RedisCacheConnection": "localhost:6379",
      "RedisCachePrefix": "library"
    },
    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "book-covers"
    }
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "user",
    "Password": "pass",
    "VirtualHost": "/"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReportsService": {
    "BaseUrl" : "http://localhost:5454/api/v1/reports"
  },
  "EmailSettings": {
    "SmtpServer": "localhost",
    "SmtpPort": 25,
    "UseSsl": false,
    "SenderName": "Библиотека",
    "SenderEmail": "noreply@library.local",
    "Username": "",
    "Password": ""
  },
  "JobSettings": {
    "Jobs": {
      "ReturnReminder": {
        "CronExpression": "0 0 6 * * *",
        "MaxRetries": 3,
        "TimeoutMinutes": 30
      },
      "WeeklyReport": {
        "CronExpression": "0 0 5 ? * MON",
        "MaxRetries": 3,
        "TimeoutMinutes": 30
      },
      "ArchiveOldBooks": {
        "CronExpression": "0 0 0 1 * *",
        "MaxRetries": 3,
        "TimeoutMinutes": 60
      }
    }
  },
  "ArchiveSettings": {
    "YearsWithoutBorrow": 3,
    "MaxBooksPerRun": 100
  },
  "EmailTemplateSettings": {
    "LibraryName": "Библиотека",
    "LibraryAddress": "г. Москва, ул. Книжная, д. 1",
    "LibraryPhone": "+7 (495) 123-45-67",
    "WorkingHours": "Пн-Пт: 9:00 - 20:00, Сб: 10:00 - 18:00",
    "ReturnReminder": {
      "SubjectTemplate": "Напоминание о возврате книги: \"{BookTitle}\"",
      "DaysBeforeDueDate": 3,
      "IntervalInHours": 24
    },
    "WeeklyReport": {
      "SubjectTemplate": "Еженедельный отчет библиотеки за период {StartDate} - {EndDate}",
      "AdminEmails": [
        "admin@library.local",
        "librarian@library.local"
      ],
      "ReportRetentionDays": 90,
      "IntervalInMinutes": 1440
    },
    "DateFormat": "dd.MM.yyyy",
    "DateTimeFormat": "dd.MM.yyyy HH:mm"
  },
  "AllowedHosts": "*"
}